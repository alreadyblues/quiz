let questions = [], current = 0, score = 0, answered = false;

function show(id) {
  ['start-screen','quiz-screen','result-screen'].forEach(s => {
    document.getElementById(s).classList.add('hidden');
  });
  document.getElementById(id).classList.remove('hidden');
}

function shuffle(arr) {
  return [...arr].sort(() => Math.random() - 0.5);
}

function startGame() {
  questions = shuffle(ALL_QUESTIONS).slice(0, 5);
  current = 0; score = 0;
  show('quiz-screen');
  showQuestion();
}

function showQuestion() {
  answered = false;
  const q = questions[current];
  document.getElementById('q-num').textContent = `문제 ${current + 1} / 5`;
  document.getElementById('score-display').textContent = `점수: ${score}점`;
  document.getElementById('progress-fill').style.width = `${(current / 5) * 100}%`;
  document.getElementById('q-text').textContent = q.question;
  document.getElementById('feedback').style.display = 'none';
  document.getElementById('next-btn').style.display = 'none';

  const container = document.getElementById('options-container');
  container.innerHTML = '';
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt-btn';
    btn.textContent = opt;
    btn.onclick = () => selectAnswer(i);
    container.appendChild(btn);
  });
}

function selectAnswer(idx) {
  if (answered) return;
  answered = true;
  const q = questions[current];
  const isCorrect = idx === q.answer;
  if (isCorrect) score += 20;

  document.querySelectorAll('.opt-btn').forEach((b, i) => {
    b.disabled = true;
    if (i === q.answer) b.classList.add('correct');
    else if (i === idx) b.classList.add('wrong');
  });

  const fb = document.getElementById('feedback');
  fb.className = `feedback ${isCorrect ? 'correct' : 'wrong'}`;
  fb.style.display = 'block';
  fb.innerHTML = `<strong>${isCorrect ? '✓ 정답!' : '✗ 오답!'}</strong><div class="expl">${q.explanation}</div>`;

  const nb = document.getElementById('next-btn');
  nb.style.display = 'block';
  nb.textContent = current + 1 < 5 ? '다음 문제 →' : '결과 보기 →';
}

function nextQuestion() {
  current++;
  if (current < 5) showQuestion();
  else showResult();
}

function showResult() {
  show('result-screen');
  const correct = score / 20;
  const grade = score === 100 ? 'S' : score >= 80 ? 'A' : score >= 60 ? 'B' : score >= 40 ? 'C' : 'D';
  const emoji = score === 100 ? '🏆' : score >= 80 ? '🎉' : score >= 60 ? '👍' : '📚';
  document.getElementById('result-emoji').textContent = emoji;
  document.getElementById('result-text').textContent = score >= 80 ? '훌륭한 시사 상식이에요!' : score >= 60 ? '꽤 잘 아시는군요!' : '더 공부해봐요!';
  document.getElementById('r-score').textContent = `${score}점`;
  document.getElementById('r-correct').textContent = `${correct}/5`;
  document.getElementById('r-grade').textContent = grade;
}
</script>
</body>
</html>
